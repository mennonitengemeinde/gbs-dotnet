@page "/admin/churches"
@using Gbs.Wasm.Store.ChurchUseCase.Actions
@using ChurchState = Gbs.Wasm.Store.ChurchUseCase.ChurchState
@attribute [Authorize(Policy = Policies.RequireAdmins)]
@inherits Fluxor.Blazor.Web.Components.FluxorComponent

@inject IState<ChurchState> ChurchState
@inject IDispatcher Dispatcher

<PageTitle>Churches - GBS</PageTitle>

<div class="tw-py-4 tw-space-y-4">
    <MudText Typo="Typo.h4">Churches</MudText>
    <MudButton StartIcon="@Icons.Filled.Add" Color="Color.Primary" Variant="Variant.Filled" Href="/admin/churches/create">
        New
    </MudButton>
</div>

<MudTable Items="@ChurchState.Value.Churches" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@ChurchState.Value.IsLoading" LoadingProgressColor="Color.Info">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Country</MudTh>
        <MudTh>Students</MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Country">@context.Country</MudTd>
        <MudTd DataLabel="Country">@context.StudentCount</MudTd>
        <MudTd Class="tw-text-end">
            <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                           Size="Size.Small" 
                           Href="@($"admin/churches/{context.Id}/edit")"/>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {

    // [CascadingParameter]
    // public ChurchState ChurchState { get; set; } = null!;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Dispatcher.Dispatch(new FetchChurchesAction());
    // await ChurchState.Fetch();
    }

}